{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run update database",
      "type": "shell",
      "command": "./Scripts/update_db.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Run Backend",
      "type": "shell",
      "command": "./Scripts/run_backend.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Pull new code",
      "type": "shell",
      "command": "./Scripts/pull_new_code.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Seed initial database",
      "type": "shell",
      "command": "./Scripts/seed_data.sh",
      "args": ["${input:env}"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile"
    }
  ],
  "inputs": [
    {
      "id": "env",
      "type": "pickString",
      "description": "Choose environment",
      "options": ["dev", "stag"]
    }
  ]
}
